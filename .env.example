# This is an example .env file for the Bitwarden CLI Secrets Provider setup.
# Copy this file to .env and update the values as needed for your environment.

# Bitwarden CLI Server base URL (full scheme + host). Replace with your instance URL.
BW_CLI_URL=https://bitwarden-cli-api.example.com

# Username and password for basic auth to protect the Bitwarden CLI API. 
# These should be set to match the credentials configured in your Traefik middleware.
BW_CLI_USER=example-user
BW_CLI_PASSWORD=example-password

# Optional: 
#   path to a CA bundle file for TLS verification
BW_CLI_CA_BUNDLE=/path/to/ca-bundle.pem
#   enable/disable strict TLS validation in code (default True)
BW_CLI_VERIFY_SSL=true
